# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# ── Supabase (required) ──────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Web Push (recommended) ───────────────────────────────────────────────
# Generate fresh keys with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# ── Transactional email (Resend — free 3000/mo) ─────────────────────────
# Sign up at https://resend.com → API Keys → copy
RESEND_API_KEY=
# Start with the shared sandbox sender below. After you verify your own
# domain at Resend, change to e.g. 'SDGMart <noreply@sdgmart.com>'
RESEND_FROM_EMAIL=SDGMart <onboarding@resend.dev>

# ── Optional ─────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# SDGMART_HTTPS=1
# PORT=3000
